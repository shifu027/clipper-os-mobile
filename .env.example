# Gemini AI Integration (optional)
# Set to 'true' to enable the Gemini AI tab in development
# In production, Gemini requires a backend proxy server — never embed API keys in client code
# See README.md → "Adding a Backend Proxy" for setup instructions
VITE_GEMINI_ENABLED=false

# Firebase Cloud Sync (optional - enables multi-device sync)
# See docs/firebase-setup.md for setup instructions
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
